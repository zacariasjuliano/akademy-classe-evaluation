<form>  
    <group id="academic_calendary" colspan="4" col="4">    
        <label name="name"/>
        <field name="name"/>    
        <label name="code"/>
        <field name="code"/> 
        <label name="start"/>
        <field name="start"/> 
        <label name="end"/>
        <field name="end"/> 
        <label name="lective_year"/>
        <field name="lective_year"/> 
    </group>  
    <notebook colspan="4">
        <page string="Descrição" id="description">
            <field name="description" widget="richtext"/>
        </page>
        <page string="Atividades" id="academic_calendary_activite">
            <field name="calendary_activites" mode="tree,form" colspan="4"
                view_ids="akademy_classe_evaluation.academic_calendary_activite_view_list,akademy_classe_evaluation.academic_calendary_activite_view_form"/>
        </page>
        <page string="Avaliações" id="calendary_avaliation">
            <field name="calendary_avaliations" mode="tree,form" colspan="4"
                view_ids="akademy_classe_evaluation.academic_calendary_avaliation_view_list,akademy_classe_evaluation.academic_calendary_avaliation_view_form"/>
        </page>
    </notebook>  
</form>
